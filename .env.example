# Copy this file to .env.local and fill in your values.
# Next.js automatically loads .env.local — OPENAI_API_KEY is read server-side.

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# AI Provider (openai | anthropic | google) — only openai is implemented
AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o

# Image provider (mock | openai) — openai falls back to mock on failure
IMAGE_PROVIDER=mock
OPENAI_IMAGE_MODEL=dall-e-3

# Blog Engine V3 (default: enabled). Set false to use Writing Brain only.
BLOG_ENGINE_V3=true

# App
NEXT_PUBLIC_APP_NAME=AI 블로그 자동 작성기

# Database (PostgreSQL / Supabase)
# Runtime(Prisma Client): transaction pooler 6543
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require"
# Prisma CLI(db push/migrate/pull): session pooler 5432 (동일 pooler 호스트)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Research provider (openai | tavily | google_search | serpapi) — only openai is implemented
RESEARCH_PROVIDER=openai

# Naver Playwright publish (server-side only — real browser by default)
NAVER_PUBLISH_ADAPTER=browser_automation
NAVER_BROWSER_MODE=playwright
NAVER_USERNAME=
NAVER_PASSWORD=
NAVER_SESSION_SECRET=
# Mock publish is disabled in the app. Set both below only for local test scripts.
# NAVER_ALLOW_MOCK=true
# NAVER_BROWSER_MODE=mock
